# База данных
DATABASE_URL="postgresql://dogovora:dogovora_secret@localhost:5432/dogovora_dev"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="замени-на-случайную-строку-минимум-32-символа"
