# База данных
DATABASE_URL="postgresql://dogovora:dogovora_secret@localhost:5433/dogovora_dev"

# Redis
REDIS_URL="redis://localhost:6380"
WORKER_CONCURRENCY=1

# JWT
JWT_SECRET="замени-на-случайную-строку-минимум-32-символа"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# S3 / Файлы
S3_ENDPOINT="https://storage.yandexcloud.net"
S3_BUCKET="dogovora-files"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="ru-central1"

# ИИ провайдер (mock, gigachat, claude или openai)
AI_PROVIDER="mock"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GIGACHAT_AUTH_KEY=""
GIGACHAT_SCOPE="GIGACHAT_API_PERS"
GIGACHAT_MODEL="GigaChat-2"
GIGACHAT_BASE_URL="https://gigachat.devices.sberbank.ru/api/v1"
GIGACHAT_AUTH_URL="https://ngw.devices.sberbank.ru:9443/api/v2/oauth"

# Приложение
NEXT_PUBLIC_API_URL="http://localhost:3001"
API_PORT=3001
WEB_PORT=3000

# Окружение
NODE_ENV="development"
