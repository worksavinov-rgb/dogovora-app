generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Пользователь ────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profiles      Profile[]
  oauthAccounts OAuthAccount[]
  wallet        Wallet?
  storageQuota  StorageQuota?
  counterparties Counterparty[]
  documents     Document[]

  @@map("users")
}

// Для будущего OAuth (Госуслуги / Яндекс ID) — таблица пустая в MVP
model OAuthAccount {
  id                String @id @default(cuid())
  userId            String
  provider          String  // "gosuslugi" | "yandex"
  providerAccountId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

// ─── Реквизиты пользователя ───────────────────────────────────────────────────

model Profile {
  id             String      @id @default(cuid())
  userId         String
  type           ProfileType
  name           String
  inn            String?
  kpp            String?
  ogrn           String?
  legalAddress   String?
  // Подписант от имени этого профиля
  signatorName   String?
  signatorPosition String?
  signatorBasis  String?
  // Файлы факсимиле и печати (пути в S3)
  signatureFilePath String?
  stampFilePath  String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankDetails BankDetail[]

  @@map("profiles")
}

enum ProfileType {
  INDIVIDUAL        // Физлицо
  SOLE_PROPRIETOR   // ИП
  COMPANY           // ООО / АО
}

// ─── Контрагенты ─────────────────────────────────────────────────────────────

model Counterparty {
  id           String   @id @default(cuid())
  userId       String
  name         String
  inn          String?
  kpp          String?
  ogrn         String?
  legalAddress String?
  email        String?
  phone        String?
  isArchived   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankDetails BankDetail[]
  signatories Signatory[]
  documents   Document[]

  @@map("counterparties")
}

model BankDetail {
  id                  String  @id @default(cuid())
  profileId           String?
  counterpartyId      String?
  bankName            String
  bik                 String
  checkingAccount     String
  correspondentAccount String

  profile      Profile?      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  counterparty Counterparty? @relation(fields: [counterpartyId], references: [id], onDelete: Cascade)

  @@map("bank_details")
}

model Signatory {
  id             String          @id @default(cuid())
  counterpartyId String
  fullName       String
  signatureName  String
  position       String
  basisType      SignatoryBasis
  poaNumber      String?
  poaDate        DateTime?
  poaExpiry      DateTime?
  poaFilePath    String?
  isDefault      Boolean         @default(false)
  createdAt      DateTime        @default(now())

  counterparty Counterparty     @relation(fields: [counterpartyId], references: [id], onDelete: Cascade)
  scopes       SignatoryScope[]

  @@map("signatories")
}

model SignatoryScope {
  id          String        @id @default(cuid())
  signatoryId String
  scope       DocumentScope

  signatory Signatory @relation(fields: [signatoryId], references: [id], onDelete: Cascade)

  @@unique([signatoryId, scope])
  @@map("signatory_scopes")
}

enum SignatoryBasis {
  CHARTER     // Устав
  POA         // Доверенность
  CERTIFICATE // Свидетельство
  REGULATION  // Положение
  OTHER       // Иное
}

enum DocumentScope {
  CONTRACT   // Договор
  APPENDIX   // Приложение
  AMENDMENT  // Доп. соглашение
  ACT        // Акт
}

// ─── Документы и версии ───────────────────────────────────────────────────────

model Document {
  id             String       @id @default(cuid())
  userId         String
  counterpartyId String
  title          String
  number         String?
  type           DocumentType
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  counterparty Counterparty @relation(fields: [counterpartyId], references: [id])
  versions     Version[]

  @@map("documents")
}

// ВАЖНО: версии — append-only. Текст/файл никогда не обновляется.
model Version {
  id         String        @id @default(cuid())
  documentId String
  number     Int
  status     VersionStatus @default(DRAFT)
  filePath   String?       // путь в S3
  fileSize   Int?          // байты
  content    String?       // текст документа (пока без S3)
  aiSettings Json          // { protectionLevel, targetSize, customInstruction }
  createdAt  DateTime      @default(now())

  document     Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chatMessages ChatMessage[]
  purchase     Purchase?
  transactions Transaction[]

  @@unique([documentId, number])
  @@map("versions")
}

model ChatMessage {
  id        String   @id @default(cuid())
  versionId String
  role      ChatRole
  content   String
  createdAt DateTime @default(now())

  version Version @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

// Покупка версии — создаётся один раз, идемпотентна
model Purchase {
  id          String   @id @default(cuid())
  versionId   String   @unique
  amount      Decimal  @db.Decimal(10, 2)
  purchasedAt DateTime @default(now())

  version Version @relation(fields: [versionId], references: [id])

  @@map("purchases")
}

enum DocumentType {
  CONTRACT   // Договор
  APPENDIX   // Приложение
  AMENDMENT  // Доп. соглашение
}

enum VersionStatus {
  DRAFT        // Черновик
  IN_PROGRESS  // В работе
  REVIEW       // На проверке
  APPROVED     // Утверждено
  PAID         // Оплачено
}

enum ChatRole {
  USER
  AI
  WARNING
}

// ─── Финансы ─────────────────────────────────────────────────────────────────

model Wallet {
  id      String  @id @default(cuid())
  userId  String  @unique
  balance Decimal @default(0) @db.Decimal(10, 2)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("wallets")
}

model Transaction {
  id               String          @id @default(cuid())
  walletId         String
  type             TransactionType
  amount           Decimal         @db.Decimal(10, 2)
  description      String
  relatedVersionId String?
  createdAt        DateTime        @default(now())

  wallet         Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  relatedVersion Version? @relation(fields: [relatedVersionId], references: [id])

  @@map("transactions")
}

enum TransactionType {
  CREDIT  // Пополнение
  DEBIT   // Списание
}

// ─── Хранилище ────────────────────────────────────────────────────────────────

model StorageQuota {
  id        String      @id @default(cuid())
  userId    String      @unique
  usedBytes BigInt      @default(0)
  limitBytes BigInt     @default(524288000) // 500 MB по умолчанию
  plan      StoragePlan @default(STARTER)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("storage_quotas")
}

enum StoragePlan {
  STARTER  // Старт
  BUSINESS // Дело
  BUREAU   // Бюро
}
